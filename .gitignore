# Rust build artifacts
target/
*.rs.bk

# Cargo lock for libraries is intentionally committed (workspace contains
# the gabby binary too).

# Coverage output
*.profraw
*.profdata
lcov.info
coverage/

# Gabby runtime assets (downloaded by setup scripts, not source)
crates/gabby/models/
crates/gabby/vendor/vosk/

# Code concatenation dumps (may contain embedded test keys)
*-COMBINED.TXT

# Local environment / secrets
.env
.env.*
!.env.example
.envrc

# IDE / editor
.idea/
.vscode/
*.swp
*.swo
*~
*.bak

# OS
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log

# Tollens skill local state (queue + quality DBs, work items)
.tollens/

# full_test runner output under crates/rsiprtp/tests/results/
# (HTML reports + run logs + transient start markers — keep .gitkeep)
crates/rsiprtp/tests/results/*.html
crates/rsiprtp/tests/results/*.log
crates/rsiprtp/tests/results/*.txt
crates/rsiprtp/tests/results/*.json
