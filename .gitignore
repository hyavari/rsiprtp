# Rust build artifacts
target/
*.rs.bk

# Cargo lock for libraries is intentionally committed (workspace contains
# the gabby binary too).

# Coverage output
*.profraw
*.profdata
lcov.info
coverage/

# Gabby runtime assets (downloaded by setup scripts, not source)
crates/gabby/models/
crates/gabby/vendor/vosk/

# Code concatenation dumps (may contain embedded test keys)
*-COMBINED.TXT

# Local environment / secrets
.env
.env.*
!.env.example
.envrc

# IDE / editor
.idea/
.vscode/
*.swp
*.swo
*~
*.bak

# OS
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log

# Tollens skill local state (queue + quality DBs, work items)
.tollens/

# full_test runner output under crates/rsiprtp/tests/results/
# (HTML reports + run logs + transient start markers — keep .gitkeep)
crates/rsiprtp/tests/results/*.html
crates/rsiprtp/tests/results/*.log
crates/rsiprtp/tests/results/*.txt
crates/rsiprtp/tests/results/*.json

# Overnight fuzz wrapper runtime artifacts (per-run libFuzzer logs and
# crash-triage scratch). Wrapper: fuzz_overnight.ps1.
wrk_journals/fuzz_logs/
wrk_journals/fuzz_triage/

# proptest persistence files (written under each crate's tests dir on
# failure; the failing seed is also in the panic message and a fresh
# regression file is regenerated on repro). proptest 1.11 writes flat
# files like `<test_name>.proptest-regressions` rather than a dir, so
# match the suffix glob too.
proptest-regressions/
*.proptest-regressions
