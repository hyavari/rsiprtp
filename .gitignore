crates/gabby/models/
crates/gabby/vendor/vosk/

# Code concatenation dumps (may contain embedded test keys)
*-COMBINED.TXT

# Local environment / secrets
.env
.env.*
!.env.example
.envrc

# IDE / editor
.idea/
.vscode/
*.swp
*.swo
*~
*.bak

# OS
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
